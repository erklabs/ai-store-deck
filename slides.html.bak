        const root6 = document.getElementById('slide-wrapper-6').attachShadow({mode: 'open'});
        root6.innerHTML = `<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=Outfit:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>

<style>* {
            box-sizing: border-box;
