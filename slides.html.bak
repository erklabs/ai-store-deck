                box-shadow: none !important;
                border: none !important;
            }
            .slide-nav-overlay {
                display: none !important;
            }
            
            /* Layout Safety Reset to prevent vertical overflows on print */
            .content-wrapper {
                padding: 30px 45px !important;
            }
